# ============================================================
# skol — environment template
#
# Local SvelteKit env (.env / .env.local):
# ============================================================

# Written by `npx convex dev` into .env.local — do not set manually.
# CONVEX_DEPLOYMENT="dev:..."
# PUBLIC_CONVEX_URL="https://<deployment>.convex.cloud"
# PUBLIC_CONVEX_SITE_URL="https://<deployment>.convex.site"

# Cloudflare R2 (image storage; server-only)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_BUCKET=""

# ============================================================
# Convex deployment env (set with `npx convex env set NAME value`):
# Better Auth runs inside Convex, so these live on the deployment.
# ============================================================

# SITE_URL="http://localhost:5173"           # app origin
# BETTER_AUTH_SECRET=""                       # random string, signs/verifies tokens
# GOOGLE_CLIENT_ID=""                         # OAuth; redirect URI: ${SITE_URL}/api/auth/callback/google
# GOOGLE_CLIENT_SECRET=""
